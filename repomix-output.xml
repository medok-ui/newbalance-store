}

.field {
  margin-bottom: 18px;
}

.form-label {
  display: block;
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: #555;
  margin-bottom: 6px;
}

.input-wrapper {
  position: relative;
  display: flex;
  width: 100%;

  .form-input {
    padding-right: 44px;
  }
}

.form-input {
  display: block;
  width: 100%;
  height: 44px;
  border: 1px solid #e8e8e8;
  border-radius: 2px;
  padding: 0 14px;
  font-size: 14px;
  color: #0a0a0a;
  background: #fff;
  outline: none;
  transition: border-color 200ms ease;

  &:focus {
    border-color: #0a0a0a;
  }
}

.form-visible__password-btn {
  position: absolute;
  right: 0;
  top: 0;
  height: 44px;
  width: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: none;
  border: none;
  cursor: pointer;
  color: #9a9a9a;
  transition: color 200ms ease;

  &:hover {
    color: #0a0a0a;
  }
}

